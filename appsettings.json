{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "shared": true
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DocumentStorage": {
    "BasePath": ".\\Documents"
  },
  "Gestiona": {
    "GestionaApiBaseUrl": "https://02.g3stiona.com/rest"
  },
  "Api": {
    "Version": "1.1.1"
  },
  "AllowedHosts": "*"
}
